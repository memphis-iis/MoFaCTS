DOCKER_REGISTRY=mofacts-local
IMAGE_NAME=mofacts-mini
IMAGE_TAG=v0.1.0-alpha.1

ROOT_URL=https://mofacts.example.org
MOFACTS_HTTP_BIND=127.0.0.1:3000
PORT=3000

METEOR_SETTINGS_HOST_PATH=./settings.self-hosted.example.json

EXPECTED_MONGO_DB_NAME=MoFACT-meteor3
MOFACTS_SELF_HOSTED=true
MOFACTS_MONGO_APP_DATABASE=MoFACT-meteor3
MONGO_INITDB_ROOT_USERNAME=mofacts_root
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-long-random-root-password
MOFACTS_MONGO_APP_USERNAME=mofacts_app
MOFACTS_MONGO_APP_PASSWORD=replace-with-a-long-random-app-password
MONGO_URL=replace-with-authenticated-mongodb-url-for-mofacts-app-user

REDIS_URL=redis://redis:6379/0
