DOCKER_REGISTRY=your-docker-registry
IMAGE_NAME=mofacts-mini
IMAGE_TAG=local
ROOT_URL=http://localhost:3100
PORT=3000
METEOR_SETTINGS_HOST_PATH=./settings.local.example.json
MONGO_URL=replace-with-authenticated-mongo-url
EXPECTED_MONGO_DB_NAME=MoFACT-meteor3
MONGO_INITDB_ROOT_USERNAME=local_root
MONGO_INITDB_ROOT_PASSWORD=local-root-password
MOFACTS_MONGO_APP_DATABASE=MoFACT-meteor3
MOFACTS_MONGO_APP_USERNAME=local_app
MOFACTS_MONGO_APP_PASSWORD=local-app-password
REDIS_URL=redis://redis:6379/0
