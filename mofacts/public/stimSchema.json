{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MoFaCTS Stimulus Schema",
  "description": "Schema for MoFaCTS stimulus files, including clusters, learner-facing display content, expected responses, media references, and alternate displays.",
  "type": "object",
  "required": [
    "setspec"
  ],
  "additionalProperties": false,
  "properties": {
    "setspec": {
      "type": "object",
      "title": "Setspec",
      "required": [
        "clusters"
      ],
      "additionalProperties": false,
      "properties": {
        "clusters": {
          "type": "array",
          "title": "Clusters",
          "items": {
            "type": "object",
            "title": "Cluster",
            "properties": {
              "imageStimulus": {
                "title": "Cluster image stimulus.",
                "description": "Cluster-level image asset used when stims inherit the shared image.",
                "type": "string",
                "default": "",
                "options": {
                  "grid_columns": 12
                }
              },
              "audioStimulus": {
                "title": "Cluster audio stimulus.",
                "description": "Cluster-level audio asset used when stims inherit the shared audio.",
                "type": "string",
                "default": "",
                "options": {
                  "grid_columns": 12
                }
              },
              "videoStimulus": {
                "title": "Cluster video stimulus.",
                "description": "Cluster-level video asset used when stims inherit the shared video.",
                "type": "string",
                "default": "",
                "options": {
                  "grid_columns": 12
                }
              },
              "stims": {
                "type": "array",
                "title": "Stims",
                "items": {
                  "type": "object",
                  "title": "Stim",
                  "properties": {
                    "parameter": {
                      "title": "Stimulus parameter metadata.",
                      "description": "Comma-separated optional parameters for advanced scoring algorithms. The second value is reserved for the item-specific optimal difficulty threshold.",
                      "type": "string",
                      "default": "",
                      "options": {
                        "grid_columns": 6
                      }
                    },
                    "optimalProb": {
                      "title": "Stimulus optimum probability override.",
                      "description": "Item-specific optimum probability used by the learning model.",
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "options": {
                        "grid_columns": 4
                      }
                    },
                    "speechHintExclusionList": {
                      "title": "Speech-hint exclusion list.",
                      "description": "Comma-delimited words to exclude from speech-recognition matching, helping prevent false positives for common words.",
                      "type": "string",
                      "default": "",
                      "options": {
                        "grid_columns": 12
                      }
                    },
                    "alternateDisplays": {
                      "title": "Alternate Displays",
                      "description": "Array of alternate display objects, such as clozeText/clozeStimulus pairs, that provide additional question variations for the same item.",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "title": "Alternate Display",
                        "properties": {
                          "text": {
                            "title": "Question/stimulus text.",
                            "description": "Main question or stimulus text displayed to the learner. HTML is supported for formatting.",
                            "type": "string",
                            "default": "",
                            "format": "textarea",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "clozeText": {
                            "title": "Cloze sentence text.",
                            "description": "Question text with a blank for fill-in. Use with clozeStimulus for the answer word.",
                            "type": "string",
                            "default": "",
                            "format": "textarea",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "clozeStimulus": {
                            "title": "Cloze answer token.",
                            "description": "The answer word to insert in the clozeText blank. Paired with clozeText for fill-in-the-blank questions.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "imgSrc": {
                            "title": "Stim image filename.",
                            "description": "Filename of the image to display as the stimulus. Accepted formats include JPEG, PNG, GIF, WebP, and SVG; the file must be uploaded in the same package.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "audioSrc": {
                            "title": "Stim audio filename.",
                            "description": "Filename of the audio to play as the stimulus. Accepted formats include MP3, WAV, OGG, and M4A; the file must be uploaded in the same package.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "videoSrc": {
                            "title": "Stim video URL or filename.",
                            "description": "URL or filename of the video to display. Accepted formats include MP4, WebM, and OGG; values can be external URLs or uploaded local files.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "h5p": {
                            "title": "H5P display",
                            "description": "H5P activity metadata for learner display. Phase 1 supports passive external iframe embeds only.",
                            "type": "object",
                            "required": [
                              "sourceType",
                              "completionPolicy"
                            ],
                            "additionalProperties": false,
                            "properties": {
                              "sourceType": {
                                "type": "string",
                                "enum": [
                                  "external-embed",
                                  "self-hosted"
                                ],
                                "default": "external-embed"
                              },
                              "embedUrl": {
                                "type": "string",
                                "default": ""
                              },
                              "completionPolicy": {
                                "type": "string",
                                "enum": [
                                  "viewed",
                                  "manual-continue",
                                  "xapi-completed",
                                  "xapi-passed"
                                ],
                                "default": "manual-continue"
                              },
                              "preferredHeight": {
                                "type": "number",
                                "minimum": 1
                              },
                              "scorePolicy": {
                                "type": "string",
                                "enum": [
                                  "correct-if-passed",
                                  "correct-if-full-score",
                                  "record-only"
                                ]
                              },
                              "contentId": {
                                "type": "string"
                              },
                              "packageAssetId": {
                                "type": "string"
                              },
                              "library": {
                                "type": "string"
                              }
                            }
                          },
                          "attribution": {
                            "title": "Attribution",
                            "description": "Creator, source, and license metadata rendered as a linked caption for the prompt media.",
                            "type": "object",
                            "properties": {
                              "creatorName": {
                                "title": "Attribution creator name.",
                                "description": "Visible creator/author name shown with licensed media.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "sourceName": {
                                "title": "Attribution source label.",
                                "description": "Visible source label shown in the attribution caption.",
                                "type": "string",
                                "default": "Wikimedia Commons",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "sourceUrl": {
                                "title": "Attribution source URL.",
                                "description": "Source page opened when the learner clicks the attribution caption.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "licenseName": {
                                "title": "Attribution license name.",
                                "description": "Visible license label shown in the attribution caption.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "licenseUrl": {
                                "title": "Attribution license URL.",
                                "description": "Optional license detail URL for the attributed media.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              }
                            },
                            "additionalProperties": false
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "display": {
                      "type": "object",
                      "title": "Display",
                      "properties": {
                        "text": {
                          "title": "Question/stimulus text.",
                          "description": "Main question or stimulus text displayed to the learner. HTML is supported for formatting.",
                          "type": "string",
                          "default": "",
                          "format": "textarea",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "clozeText": {
                          "title": "Cloze sentence text.",
                          "description": "Question text with a blank for fill-in. Use with clozeStimulus for the answer word.",
                          "type": "string",
                          "default": "",
                          "format": "textarea",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "clozeStimulus": {
                          "title": "Cloze answer token.",
                          "description": "The answer word to insert in the clozeText blank. Paired with clozeText for fill-in-the-blank questions.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "imgSrc": {
                          "title": "Stim image filename.",
                          "description": "Filename of the image to display as the stimulus. Accepted formats include JPEG, PNG, GIF, WebP, and SVG; the file must be uploaded in the same package.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "audioSrc": {
                          "title": "Stim audio filename.",
                          "description": "Filename of the audio to play as the stimulus. Accepted formats include MP3, WAV, OGG, and M4A; the file must be uploaded in the same package.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "videoSrc": {
                          "title": "Stim video URL or filename.",
                          "description": "URL or filename of the video to display. Accepted formats include MP4, WebM, and OGG; values can be external URLs or uploaded local files.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "h5p": {
                          "title": "H5P display",
                          "description": "H5P activity metadata for learner display. Phase 1 supports passive external iframe embeds only.",
                          "type": "object",
                          "required": [
                            "sourceType",
                            "completionPolicy"
                          ],
                          "additionalProperties": false,
                          "properties": {
                            "sourceType": {
                              "type": "string",
                              "enum": [
                                "external-embed",
                                "self-hosted"
                              ],
                              "default": "external-embed"
                            },
                            "embedUrl": {
                              "type": "string",
                              "default": ""
                            },
                            "completionPolicy": {
                              "type": "string",
                              "enum": [
                                "viewed",
                                "manual-continue",
                                "xapi-completed",
                                "xapi-passed"
                              ],
                              "default": "manual-continue"
                            },
                            "preferredHeight": {
                              "type": "number",
                              "minimum": 1
                            },
                            "scorePolicy": {
                              "type": "string",
                              "enum": [
                                "correct-if-passed",
                                "correct-if-full-score",
                                "record-only"
                              ]
                            },
                            "contentId": {
                              "type": "string"
                            },
                            "packageAssetId": {
                              "type": "string"
                            },
                            "library": {
                              "type": "string"
                            }
                          }
                        },
                        "attribution": {
                          "title": "Attribution",
                          "description": "Creator, source, and license metadata rendered as a linked caption for the prompt media.",
                          "type": "object",
                          "properties": {
                            "creatorName": {
                              "title": "Attribution creator name.",
                              "description": "Visible creator/author name shown with licensed media.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "sourceName": {
                              "title": "Attribution source label.",
                              "description": "Visible source label shown in the attribution caption.",
                              "type": "string",
                              "default": "Wikimedia Commons",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "sourceUrl": {
                              "title": "Attribution source URL.",
                              "description": "Source page opened when the learner clicks the attribution caption.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "licenseName": {
                              "title": "Attribution license name.",
                              "description": "Visible license label shown in the attribution caption.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "licenseUrl": {
                              "title": "Attribution license URL.",
                              "description": "Optional license detail URL for the attributed media.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            }
                          },
                          "additionalProperties": false
                        }
                      },
                      "additionalProperties": false
                    },
                    "response": {
                      "type": "object",
                      "title": "Response",
                      "properties": {
                        "correctResponse": {
                          "title": "Expected correct response.",
                          "description": "The exact answer the learner should provide. Used for answer evaluation and feedback.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "incorrectResponses": {
                          "title": "Incorrect Responses",
                          "description": "Array of common incorrect answers. Optional, but useful for multiple-choice distractors and speech-recognition grammar support.",
                          "type": "array",
                          "items": {
                            "type": "string",
                            "title": "Incorrect Response"
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
