{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MoFaCTS Stimulus Schema",
  "description": "Registry-backed stimulus schema.",
  "type": "object",
  "required": [
    "setspec"
  ],
  "additionalProperties": false,
  "properties": {
    "setspec": {
      "type": "object",
      "title": "Setspec",
      "required": [
        "clusters"
      ],
      "additionalProperties": false,
      "properties": {
        "clusters": {
          "type": "array",
          "title": "Clusters",
          "items": {
            "type": "object",
            "title": "Cluster",
            "properties": {
              "imageStimulus": {
                "title": "Cluster image stimulus.",
                "type": "string",
                "default": "",
                "options": {
                  "grid_columns": 12
                }
              },
              "audioStimulus": {
                "title": "Cluster audio stimulus.",
                "type": "string",
                "default": "",
                "options": {
                  "grid_columns": 12
                }
              },
              "videoStimulus": {
                "title": "Cluster video stimulus.",
                "type": "string",
                "default": "",
                "options": {
                  "grid_columns": 12
                }
              },
              "stims": {
                "type": "array",
                "title": "Stims",
                "items": {
                  "type": "object",
                  "title": "Stim",
                  "properties": {
                    "parameter": {
                      "title": "Stimulus parameter metadata.",
                      "type": "string",
                      "default": "",
                      "options": {
                        "grid_columns": 6
                      }
                    },
                    "optimalProb": {
                      "title": "Stimulus optimum probability override.",
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "options": {
                        "grid_columns": 4
                      }
                    },
                    "speechHintExclusionList": {
                      "title": "Speech-hint exclusion list.",
                      "type": "string",
                      "default": "",
                      "options": {
                        "grid_columns": 12
                      }
                    },
                    "alternateDisplays": {
                      "title": "Alternate Displays",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "title": "Alternate Display",
                        "properties": {
                          "text": {
                            "title": "Question/stimulus text.",
                            "type": "string",
                            "default": "",
                            "format": "textarea",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "clozeText": {
                            "title": "Cloze sentence text.",
                            "type": "string",
                            "default": "",
                            "format": "textarea",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "clozeStimulus": {
                            "title": "Cloze answer token.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "imgSrc": {
                            "title": "Stim image filename.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "audioSrc": {
                            "title": "Stim audio filename.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "videoSrc": {
                            "title": "Stim video URL or filename.",
                            "type": "string",
                            "default": "",
                            "options": {
                              "grid_columns": 12
                            }
                          },
                          "attribution": {
                            "title": "Attribution",
                            "type": "object",
                            "properties": {
                              "creatorName": {
                                "title": "Attribution creator name.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "sourceName": {
                                "title": "Attribution source label.",
                                "type": "string",
                                "default": "Wikimedia Commons",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "sourceUrl": {
                                "title": "Attribution source URL.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "licenseName": {
                                "title": "Attribution license name.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              },
                              "licenseUrl": {
                                "title": "Attribution license URL.",
                                "type": "string",
                                "default": "",
                                "options": {
                                  "grid_columns": 12
                                }
                              }
                            },
                            "additionalProperties": false
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "display": {
                      "type": "object",
                      "title": "Display",
                      "properties": {
                        "text": {
                          "title": "Question/stimulus text.",
                          "type": "string",
                          "default": "",
                          "format": "textarea",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "clozeText": {
                          "title": "Cloze sentence text.",
                          "type": "string",
                          "default": "",
                          "format": "textarea",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "clozeStimulus": {
                          "title": "Cloze answer token.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "imgSrc": {
                          "title": "Stim image filename.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "audioSrc": {
                          "title": "Stim audio filename.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "videoSrc": {
                          "title": "Stim video URL or filename.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "attribution": {
                          "title": "Attribution",
                          "type": "object",
                          "properties": {
                            "creatorName": {
                              "title": "Attribution creator name.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "sourceName": {
                              "title": "Attribution source label.",
                              "type": "string",
                              "default": "Wikimedia Commons",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "sourceUrl": {
                              "title": "Attribution source URL.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "licenseName": {
                              "title": "Attribution license name.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            },
                            "licenseUrl": {
                              "title": "Attribution license URL.",
                              "type": "string",
                              "default": "",
                              "options": {
                                "grid_columns": 12
                              }
                            }
                          },
                          "additionalProperties": false
                        }
                      },
                      "additionalProperties": false
                    },
                    "response": {
                      "type": "object",
                      "title": "Response",
                      "properties": {
                        "correctResponse": {
                          "title": "Expected correct response.",
                          "type": "string",
                          "default": "",
                          "options": {
                            "grid_columns": 12
                          }
                        },
                        "incorrectResponses": {
                          "title": "Incorrect Responses",
                          "type": "array",
                          "items": {
                            "type": "string",
                            "title": "Incorrect Response"
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
