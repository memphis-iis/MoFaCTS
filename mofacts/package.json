{
  "name": "mofacts",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Mobile Fact and Concept Training System, a web-based adaptive learning system.",
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "brace-expansion": "^2.0.3",
    "follow-redirects": "^1.16.0",
    "node-forge": "^1.4.0",
    "yaml": "^2.8.3",
    "validator": "^13.12.0",
    "fast-xml-parser": "^5.7.1",
    "qs": "^6.15.2",
    "ajv": "^8.18.0",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "^6.14.0"
    },
    "minimatch": "^9.0.9",
    "shell-quote": "^1.8.4",
    "serialize-javascript": "^7.0.4",
    "terser-webpack-plugin": "^5.4.0",
    "@types/node": "^22.19.11",
    "browserify-sign": {
      "bn.js": "^5.2.3"
    },
    "browserify-rsa": {
      "bn.js": "^5.2.3"
    },
    "elliptic": {
      "bn.js": "^4.12.3"
    },
    "asn1.js": {
      "bn.js": "^4.12.3"
    },
    "create-ecdh": {
      "bn.js": "^4.12.3"
    },
    "diffie-hellman": {
      "bn.js": "^4.12.3"
    },
    "miller-rabin": {
      "bn.js": "^4.12.3"
    },
    "public-encrypt": {
      "bn.js": "^4.12.3"
    }
  },
  "dependencies": {
    "@aws-sdk/client-mturk": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@babel/runtime": "^7.29.2",
    "@node-saml/node-saml": "^5.1.0",
    "@smithy/types": "^4.14.2",
    "@swc/helpers": "^0.5.21",
    "@tiptap/core": "^3.27.0",
    "@tiptap/extension-color": "^3.27.0",
    "@tiptap/extension-highlight": "^3.27.0",
    "@tiptap/extension-image": "^3.27.0",
    "@tiptap/extension-link": "^3.27.0",
    "@tiptap/extension-placeholder": "^3.27.0",
    "@tiptap/extension-strike": "^3.27.0",
    "@tiptap/extension-subscript": "^3.27.0",
    "@tiptap/extension-superscript": "^3.27.0",
    "@tiptap/extension-table": "^3.27.0",
    "@tiptap/extension-table-cell": "^3.27.0",
    "@tiptap/extension-table-header": "^3.27.0",
    "@tiptap/extension-table-row": "^3.27.0",
    "@tiptap/extension-task-item": "^3.27.0",
    "@tiptap/extension-task-list": "^3.27.0",
    "@tiptap/extension-text-align": "^3.27.0",
    "@tiptap/extension-text-style": "^3.27.0",
    "@tiptap/extension-typography": "^3.27.0",
    "@tiptap/extension-underline": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "connect": "^3.7.0",
    "deep-chat": "^2.4.2",
    "dompurify": "^3.4.11",
    "double-metaphone": "^2.0.0",
    "fast-xml-parser": "^5.7.1",
    "jquery": "^3.7.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.2",
    "meteor-node-stubs": "^1.2.27",
    "plyr": "^3.8.4",
    "sql.js": "^1.14.1",
    "svelte": "^5.55.0",
    "underscore": "^1.13.8",
    "unzipper": "^0.12.3",
    "wildemitter": "^1.2.1",
    "xstate": "^5.31.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@meteorjs/rspack": "^2.0.1",
    "@playwright/test": "^1.60.0",
    "@rsdoctor/rspack-plugin": "^1.5.11",
    "@rspack/cli": "^1.7.1",
    "@rspack/core": "^1.7.1",
    "@types/chai": "^5.2.3",
    "@types/jquery": "^3.5.13",
    "@types/meteor": "^2.9.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.11",
    "@types/sinon": "^21.0.0",
    "@types/underscore": "^1.11.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "eslint": "^9.39.4",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.4.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.2.7",
    "postcss-load-config": "^5.1.0",
    "sinon": "^18.0.0",
    "svelte-loader": "^3.2.4",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.9.3"
  },
  "meteor": {
    "modern": true,
    "mainModule": {
      "client": "client/index.ts",
      "server": "server/main.ts"
    },
    "testModule": {
      "client": "tests/client-entry.js",
      "server": "tests/server-entry.js"
    },
    "modules": [
      "client"
    ]
  },
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "test": "TEST_WATCH=1 meteor test --driver-package=meteortesting:mocha --port 3010 --settings settings.json",
    "test:ci": "node scripts/runMeteorCiTest.cjs",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov --report-dir coverage meteor test --once --driver-package=meteortesting:mocha --port 3010 --settings settings.json",
    "docs:api": "node scripts/generateApiDocs.js",
    "generate:schemas": "node --experimental-strip-types scripts/generateSchemas.ts",
    "check:sparc-authoring": "node scripts/checkSparcAuthoringEditor.cjs",
    "check:sparc-rich-html": "node scripts/checkSparcRichHtml.cjs",
    "lint": "cd .. && node mofacts/node_modules/eslint/bin/eslint.js -c eslint.config.mjs mofacts \"learning-components/**/*.ts\" \"examples/**/*.ts\" \"packages/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "cd .. && node mofacts/node_modules/eslint/bin/eslint.js -c eslint.config.mjs mofacts \"learning-components/**/*.ts\" \"examples/**/*.ts\" \"packages/**/*.ts\" --no-error-on-unmatched-pattern --fix",
    "license:audit": "npx license-checker --production --summary && npx license-checker --production --csv --out ../dependency-licenses.csv",
    "license:audit:all": "npx license-checker --summary && npx license-checker --csv --out ../dependency-licenses-all.csv",
    "audit:fields": "node --experimental-strip-types scripts/auditFields.ts",
    "audit:menu-theme": "node scripts/auditMenuTheme.mjs",
    "convert:config-delivery-settings": "node --experimental-strip-types scripts/convertConfigDeliverySettings.ts",
    "convert:sparc-autotutor-target-schema": "node --experimental-strip-types scripts/convertSparcAutoTutorTargetSchema.ts",
    "check:sparc-autotutor-runtime-cleanup": "node scripts/checkSparcAutoTutorRuntimeCleanup.cjs",
    "prepare": "node scripts/prepare-husky.cjs",
    "precommit:lint-staged": "lint-staged",
    "secret:scan:staged": "node scripts/scan-staged-secrets.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:vendor": "tsc --noEmit -p tsconfig.vendor-check.json",
    "knip": "knip --include files,dependencies,unlisted,binaries,unresolved,duplicates --no-config-hints",
    "knip:exports": "knip --include exports,types,enumMembers,namespaceMembers --include-entry-exports --no-config-hints",
    "audit:runtime-fields": "python scripts/audit_runtime_field_refs.py"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,svelte}": [
      "eslint --ignore-pattern .meteor/** --ignore-pattern public/h5p-standalone/** --ignore-pattern public/vendor/** --fix"
    ]
  },
  "author": "",
  "license": "AGPL-3.0-only"
}
