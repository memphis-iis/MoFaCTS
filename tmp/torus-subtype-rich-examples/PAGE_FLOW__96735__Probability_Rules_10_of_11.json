      },
      {
        "children": [
          {
            "children": [
              {
                "children": [
                  {
                    "text": "Title"
                  }
                ],
                "id": "ji7nvixdyyfo6jh",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "Recall the smoke detector example from the last activity. Here is a quick recap:"
                  }
                ],
                "id": "daa241cc08a24d8f8f26f2a9ad35719f",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "D—the dining room alarm is set off by smoke in the kitchen"
                  }
                ],
                "id": "ca584754f6eb44699865569260e862ab",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "B—the bedroom alarm is set off by smoke in the kitchen "
                  }
                ],
                "id": "ecd254a282e84094b95b923c05e92b2a",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "P(D) = 0.95 "
                  }
                ],
                "id": "f33352038bda47e18760683925420211",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "P(B) = 0.40"
                  }
                ],
                "id": "ed958dde1e6e484cbc22f4be23f18821",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "D and B are independent → P(D and B) = 0.38"
                  }
                ],
                "id": "c729447e2f2040b5af21059955795729",
                "type": "p"
              },
              {
                "children": [
                  {
                    "text": "Complete the table below. Start with the information that is given and go from there."
                  }
                ],
                "id": "e770c866878140448148ce1cfb47e5f7",
                "type": "p"
              }
            ],
            "id": "910250581",
