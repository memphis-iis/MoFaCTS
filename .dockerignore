# Dependency directories - will be installed fresh in Docker
mofacts/node_modules/
node_modules/

# Meteor local build cache (NEVER include this!)
mofacts/.meteor/local/
.meteor/local/

# Logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Testing
mofacts/tests/*
!mofacts/tests/client-entry.js
!mofacts/tests/server-entry.js

# Documentation (optional, can remove if needed in image)
docs/
docs_dev/

# Local settings. Deploy settings are copied explicitly by Dockerfile.
mofacts/settings.json
settings.json
!deploy/settings.json
!deploy/settingsstaging.json

# Private deploy/runtime state
deploy/.env*
deploy/.gemini/
deploy/local-data/
deploy/local-dev/
deploy/local-build/

# Build artifacts
*.pyc
__pycache__/
